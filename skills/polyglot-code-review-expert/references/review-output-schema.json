{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.codex/skills/polyglot-code-review-expert/review-output-schema.json",
  "title": "PolyglotCodeReviewOutput",
  "type": "object",
  "required": [
    "review_scope",
    "summary",
    "findings",
    "validation",
    "assumptions",
    "unreviewed_areas"
  ],
  "properties": {
    "review_scope": {
      "type": "object",
      "required": [
        "workspace",
        "target",
        "files_reviewed",
        "policy_docs",
        "frameworks"
      ],
      "properties": {
        "workspace": { "type": "string" },
        "target": { "type": "string" },
        "files_reviewed": {
          "type": "array",
          "items": { "type": "string" }
        },
        "policy_docs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "frameworks": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "summary": {
      "type": "object",
      "required": [
        "overall_risk",
        "finding_count",
        "critical_count",
        "note"
      ],
      "properties": {
        "overall_risk": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"]
        },
        "finding_count": { "type": "integer", "minimum": 0 },
        "critical_count": { "type": "integer", "minimum": 0 },
        "note": { "type": "string" }
      },
      "additionalProperties": false
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "severity",
          "title",
          "file",
          "confidence",
          "category",
          "impact",
          "evidence",
          "recommendation",
          "suggested_validation"
        ],
        "properties": {
          "id": { "type": "string" },
          "severity": {
            "type": "string",
            "enum": ["P0", "P1", "P2", "P3"]
          },
          "title": { "type": "string" },
          "file": { "type": "string" },
          "line": {
            "type": ["integer", "null"],
            "minimum": 1
          },
          "symbol": {
            "type": ["string", "null"]
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "category": { "type": "string" },
          "impact": { "type": "string" },
          "evidence": { "type": "string" },
          "recommendation": { "type": "string" },
          "suggested_validation": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "validation": {
      "type": "object",
      "required": ["performed", "recommended", "gaps"],
      "properties": {
        "performed": {
          "type": "array",
          "items": { "type": "string" }
        },
        "recommended": {
          "type": "array",
          "items": { "type": "string" }
        },
        "gaps": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "assumptions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "unreviewed_areas": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
