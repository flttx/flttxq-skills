{
  "name": "flttxq-skills",
  "version": "0.1.0",
  "description": "用于安装和分发自定义全局 skills 的命令行工具。",
  "bin": {
    "flttxq-skills": "./bin/flttxq-skills.js",
    "add": "./bin/add.js"
  },
  "files": [
    "bin",
    "docs",
    "install.ps1",
    "install.sh",
    "scripts",
    "skills",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "check:skills": "node ./bin/flttxq-skills.js --list-skills",
    "check:platforms": "node ./bin/flttxq-skills.js --list-platforms"
  },
  "keywords": [
    "skills",
    "codex",
    "cli"
  ],
  "license": "MIT"
}
